rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: categories
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required) - Category name
    //   - createdAt: timestamp string (required)
    //
    // Collection: questions
    // Document ID: auto-generated
    // Fields:
    //   - text: string (required) - Question text
    //   - options: list (required, 4 items for MC, empty for essay)
    //   - correctOption: int (required, 0-3 for MC, -1 for essay)
    //   - categoryId: string (required) - Reference to category
    //   - exerciseType: string (required) - Type of exercise
    //   - essayAnswer: string (optional) - Answer for essay questions
    //   - hint: string (optional) - Hint for essay questions
    //   - explanation: string (optional) - Explanation
    //   - difficulty: int (required, 1-3) - Difficulty level
    //   - createdAt: timestamp string (required)
    //   - passage: string (optional) - Reading passage
    //   - passageId: string (optional) - Reading passage ID
    //
    // Collection: users
    // Document ID: userId (auth.uid)
    // Fields:
    //   - email: string (required)
    //   - role: string (required, 'admin', 'editor' or 'user')
    //
    // Collection: exam_results
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - userEmail: string (required)
    //   - studentName: string (optional)
    //   - studentClass: string (optional)
    //   - examSource: string (required)
    //   - score: number (required)
    //   - correctCount: number (required)
    //   - totalQuestions: number (required)
    //   - completedAt: timestamp string (required)
    //
    // Collection: school_accounts
    // Document ID: auto-generated
    // Fields:
    //   - username: string (required)
    //   - password: string (required)
    //   - schoolName: string (required)
    //   - createdAt: timestamp string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((request.auth.token.email != null && 
          (request.auth.token.email.lower() == "nguyencam94@gmail.com" || 
           request.auth.token.email.lower() == "modestman94@gmail.com")) ||
         request.auth.uid == "oRTlgyIjo8V6OB94x5QBy39TL5l2" || 
         request.auth.uid == "sCrTPGhYb6Qa9XF79QXZppmFbzw1" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isEditor() {
      return isAuthenticated() &&
        (isAdmin() || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor'));
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.createdAt is string;
    }

    function isValidQuestion(data) {
      let isEssay = 'exerciseType' in data && data.exerciseType == 'essay';
      
      return data.keys().hasAll(['text', 'options', 'correctOption', 'categoryId', 'createdAt']) &&
             data.text is string && data.text.size() > 0 && data.text.size() < 5000 &&
             data.options is list && (isEssay ? data.options.size() == 0 : data.options.size() == 4) &&
             data.correctOption is int && (isEssay ? data.correctOption == -1 : (data.correctOption >= 0 && data.correctOption <= 3)) &&
             data.categoryId is string &&
             data.createdAt is string &&
             (!('exerciseType' in data) || (data.exerciseType is string && data.exerciseType in ['multiple_choice', 'fill_blank', 'error_find', 'synonym_antonym', 'pronunciation_stress', 'sentence_transformation', 'reorder', 'reading_comprehension', 'reading', 'picture_guess', 'essay', 'other'])) &&
             (!('essayAnswer' in data) || (data.essayAnswer is string && data.essayAnswer.size() < 5000)) &&
             (!('hint' in data) || (data.hint is string && data.hint.size() < 1000)) &&
             (!('difficulty' in data) || (data.difficulty is int && data.difficulty >= 1 && data.difficulty <= 3)) &&
             (!('explanation' in data) || (data.explanation is string && data.explanation.size() < 5000)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 1000)) &&
             (!('source' in data) || (data.source is string && data.source.size() < 500)) &&
             (!('passage' in data) || (data.passage is string && data.passage.size() < 20000)) &&
             (!('passageId' in data) || (data.passageId is string && data.passageId.size() < 200)) &&
             (!('authorId' in data) || (data.authorId is string)) &&
             (!('order' in data) || (data.order is int));
    }

    function isValidUserCreate(data) {
      return data.keys().hasAll(['email', 'role', 'uid']) &&
             data.email is string &&
             data.role in ['admin', 'editor', 'user'] &&
             data.uid is string;
    }

    function isValidUserUpdate(data) {
      // For updates, we might only send partial data (like just 'role')
      return (!('role' in data) || data.role in ['admin', 'editor', 'user']) &&
             (!('email' in data) || data.email is string) &&
             (!('uid' in data) || data.uid is string);
    }

    function isValidGrammar(data) {
      return data.title is string && data.title.size() > 0 &&
             data.content is string && data.content.size() > 0 &&
             data.createdAt is string &&
             (!('authorId' in data) || (data.authorId is string));
    }

    function isValidExamResult(data) {
      return data.keys().hasAll(['userId', 'userEmail', 'examSource', 'score', 'correctCount', 'totalQuestions', 'completedAt']) &&
             (isAuthenticated() ? data.userId == request.auth.uid : true) &&
             data.userEmail is string &&
             data.examSource is string &&
             data.score is number &&
             data.correctCount is number &&
             data.totalQuestions is number &&
             data.completedAt is string &&
             (!('studentName' in data) || (data.studentName == null || (data.studentName is string && data.studentName.size() < 200))) &&
             (!('studentClass' in data) || (data.studentClass == null || (data.studentClass is string && data.studentClass.size() < 50)));
    }

    function isValidSchoolAccount(data) {
      return data.keys().hasAll(['username', 'password', 'schoolName', 'createdAt']) &&
             data.username is string && data.username.size() > 0 &&
             data.password is string && data.password.size() > 0 &&
             data.schoolName is string && data.schoolName.size() > 0 &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCategory(request.resource.data);
      allow update: if isAdmin() && isValidCategory(request.resource.data);
      allow delete: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if true;
      allow create: if isEditor() && isValidQuestion(request.resource.data) && 
                    (isAdmin() || request.resource.data.authorId == request.auth.uid);
      allow update: if isEditor() && isValidQuestion(request.resource.data) && 
                    (isAdmin() || resource.data.authorId == request.auth.uid);
      allow delete: if isEditor() && (isAdmin() || resource.data.authorId == request.auth.uid);
    }

    match /exam_configs/{sourceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated(); // Allow all authenticated users to read profiles (needed for author display)
      allow create: if (isOwner(userId) && isValidUserCreate(request.resource.data) && 
                     (request.resource.data.role == 'user' || 
                      (request.resource.data.role == 'admin' && 
                       (request.auth.token.email.lower() == "nguyencam94@gmail.com" || 
                        request.auth.token.email.lower() == "modestman94@gmail.com")))) || 
                    isAdmin();
      allow update: if (isOwner(userId) && isValidUserUpdate(request.resource.data) && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)) || 
                    isAdmin();
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.token.email.lower() == resource.data.email.lower());
    }

    match /grammar/{topicId} {
      allow read: if true;
      allow create: if isEditor() && isValidGrammar(request.resource.data) && 
                    (isAdmin() || request.resource.data.authorId == request.auth.uid);
      allow update: if isEditor() && isValidGrammar(request.resource.data) && 
                    (isAdmin() || resource.data.authorId == request.auth.uid);
      allow delete: if isEditor() && (isAdmin() || resource.data.authorId == request.auth.uid);
    }

    match /exam_results/{resultId} {
      allow read: if (isAuthenticated() && (resource.data.userId == request.auth.uid || isEditor())) || 
                     (!isAuthenticated() && resource.data.userId != null); // Allow school students to see their results (simplified)
      allow create: if (isAuthenticated() || true) && isValidExamResult(request.resource.data);
      allow update: if false; // Results should be immutable
      allow delete: if isAdmin();
    }

    match /school_accounts/{accountId} {
      allow read: if true; // Needed for login query
      allow create: if isAdmin() && isValidSchoolAccount(request.resource.data);
      allow update: if isAdmin() && isValidSchoolAccount(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
